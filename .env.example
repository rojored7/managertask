# Environment
NODE_ENV=development

# Backend API
BACKEND_PORT=4004
BACKEND_HOST=localhost

# Frontend
FRONTEND_PORT=3004
FRONTEND_HOST=localhost

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/managertask?schema=public
DB_HOST=localhost
DB_PORT=5437
DB_NAME=managertask
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6384
REDIS_HOST=localhost
REDIS_PORT=6384

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# CORS
CORS_ORIGIN=http://localhost:3004

# Logging
LOG_LEVEL=info

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email (for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@managertask.com

# Frontend API URL
VITE_API_URL=http://localhost:4004/api
VITE_APP_NAME=managertask
VITE_APP_VERSION=1.0.0